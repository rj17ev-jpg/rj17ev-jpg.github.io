---
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post, id } = Astro.props
const url = `/posts/${id ?? post.id}`

const { title, description, published, tags, coverImage, coverUrl } = post.data
const imgSrc = coverUrl ?? (coverImage ? coverImage.src.src : null)
const imgAlt = coverImage?.alt ?? title
---

<a href={url} class="post-card">
  <div class="post-card-image">
  {imgSrc
    ? <img src={imgSrc} alt={imgAlt} />
    : <div class="post-card-placeholder" />
  }
  </div>
  <div class="post-card-body">
    <h3>{title}</h3>
    {description && <p class="post-card-desc">{description}</p>}
    <div class="post-card-meta">
      <time>{published.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
      {tags && tags.length > 0 && (
        <div class="post-card-tags">
          {tags.slice(0, 3).map(tag => <span class="post-card-tag">{tag}</span>)}
        </div>
      )}
    </div>
  </div>
</a>

<style>
.post-card {
  display: flex;
  flex-direction: column;
  border: 2px solid color-mix(in oklab, var(--color-foreground) 10%, transparent);
  border-radius: 0.75rem;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.2s, transform 0.2s;
}

.post-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-2px);
}

.post-card-image {
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: color-mix(in oklab, var(--color-foreground) 6%, transparent);
}

.post-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border: none;
  border-radius: 0;
  margin: 0;
}

.post-card-placeholder {
  width: 100%;
  height: 100%;
  background: color-mix(in oklab, var(--color-accent) 8%, transparent);
}

.post-card-body {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.post-card-body h3 {
  margin: 0;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-heading3);
  line-height: 1.4;
}

.post-card-desc {
  margin: 0;
  font-size: 0.85rem;
  opacity: 0.75;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-card-meta {
  margin-top: auto;
  padding-top: 0.5rem;
  font-size: 0.8rem;
  opacity: 0.6;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.post-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
}

.post-card-tag {
  background: color-mix(in oklab, var(--color-accent) 12%, transparent);
  color: var(--color-accent);
  padding: 0.1rem 0.5rem;
  border-radius: 999px;
  font-size: 0.75rem;
}
</style>