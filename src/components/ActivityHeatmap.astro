---
import { getCollection } from 'astro:content'

const posts = await getCollection('posts', ({ data }) => data.project && !data.draft)

const activityMap: Record<string, number> = {}
for (const post of posts) {
  if (!post.data.last_updated) continue
  const d = post.data.last_updated
  const dateStr = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`
  activityMap[dateStr] = (activityMap[dateStr] ?? 0) + 1
}

const maxCount = Object.values(activityMap).length > 0
  ? Math.max(...Object.values(activityMap))
  : 1

function toLocaleDateStr(d: Date) {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`
}

// Generate last 365 days
const today = new Date()
// const days: { date: string; count: number; weekday: number }[] = []
// Generate from Jan 1 of this year to today
const startOfYear = new Date(today.getFullYear(), 0, 1)
const days: { date: string; count: number; weekday: number }[] = []
let cursor = new Date(startOfYear)
while (cursor <= today) {
  days.push({
    date: toLocaleDateStr(cursor),
    count: activityMap[toLocaleDateStr(cursor)] ?? 0,
    weekday: cursor.getDay(),
  })
  cursor.setDate(cursor.getDate() + 1)
}
// Pad front so first week starts on Sunday
const firstWeekday = days[0].weekday
const paddedDays: ({ date: string; count: number; weekday: number } | null)[] = [
  ...Array(firstWeekday).fill(null),
  ...days,
]

// Build weeks as columns
const weeks: ({ date: string; count: number } | null)[][] = []
for (let i = 0; i < paddedDays.length; i += 7) {
  weeks.push(paddedDays.slice(i, i + 7))
}

// Month label per column: label appears on first week of a new month
const monthLabels: (string | null)[] = weeks.map(week => {
  const firstReal = week.find(d => d !== null)
  if (!firstReal) return null
  const d = new Date(firstReal.date)
  // Only label if this is the first week where this month appears
  const prevWeekIdx = weeks.indexOf(week) - 1
  if (prevWeekIdx < 0) return d.toLocaleString('default', { month: 'short' })
  const prevReal = weeks[prevWeekIdx].find(d => d !== null)
  if (!prevReal) return d.toLocaleString('default', { month: 'short' })
  const prevMonth = new Date(prevReal.date).getMonth()
  if (new Date(firstReal.date).getMonth() !== prevMonth) {
    return d.toLocaleString('default', { month: 'short' })
  }
  return null
})

function intensityClass(count: number): string {
  if (count === 0) return 'level-0'
  const ratio = count / maxCount
  if (ratio < 0.25) return 'level-1'
  if (ratio < 0.5)  return 'level-2'
  if (ratio < 0.75) return 'level-3'
  return 'level-4'
}

const totalActive = Object.keys(activityMap).length
const currentStreak = (() => {
  let streak = 0
  const d = new Date(today)
  while (true) {
    const s = toLocaleDateStr(d)
    if (activityMap[s]) {
      streak++
      d.setDate(d.getDate() - 1)
    } else break
  }
  return streak
})()
---

<div class="heatmap-wrapper">
  <div class="heatmap-stats">
    <span><strong>{totalActive}</strong> days logged</span>
    <span><strong>{currentStreak}</strong> day streak</span>
  </div>

  <div class="heatmap-scroll">
    <div class="heatmap-grid">
      {weeks.map((week, col) => (
        <div class="heatmap-col">
          <div class="month-label">{monthLabels[col] ?? ''}</div>
          {week.map(day =>
            day === null
              ? <div class="day-cell empty" />
              : <div
                  class={`day-cell ${intensityClass(day.count)}`}
                  title={`${day.date}${day.count ? ` · ${day.count} project${day.count > 1 ? 's' : ''}` : ''}`}
                />
          )}
        </div>
      ))}
    </div>
  </div>

  <div class="heatmap-legend">
    <span>less</span>
    <div class="level-0 legend-cell" />
    <div class="level-1 legend-cell" />
    <div class="level-2 legend-cell" />
    <div class="level-3 legend-cell" />
    <div class="level-4 legend-cell" />
    <span>more</span>
  </div>
</div>

<style>
.heatmap-wrapper {
  margin: 1rem 0 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.heatmap-stats {
  display: flex;
  gap: 1.5rem;
  font-size: 0.85rem;
  opacity: 0.8;
}

.heatmap-scroll {
  overflow-x: auto;
  padding-bottom: 0.25rem;
}

.heatmap-grid {
  display: flex;
  flex-direction: row;
  gap: 3px;
  width: max-content;
}

.heatmap-col {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.month-label {
  font-size: 0.7rem;
  opacity: 0.55;
  line-height: 1rem;
  height: 1rem;
  white-space: nowrap;
}

.day-cell {
  width: 11px;
  height: 11px;
  border-radius: 2px;
  flex-shrink: 0;
}

.day-cell.empty {
  background: transparent;
}

.level-0 { background: color-mix(in oklab, var(--color-foreground) 6%, transparent); }
.level-1 { background: color-mix(in oklab, var(--color-accent) 25%, var(--color-background)); }
.level-2 { background: color-mix(in oklab, var(--color-accent) 45%, var(--color-background)); }
.level-3 { background: color-mix(in oklab, var(--color-accent) 70%, var(--color-background)); }
.level-4 { background: var(--color-accent); }

.heatmap-legend {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 0.7rem;
  opacity: 0.55;
}

.legend-cell {
  width: 11px;
  height: 11px;
  border-radius: 2px;
}
</style>