---
// src/pages/projects.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/Layout.astro'; // adjust import to match your theme

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.project);

const statusOrder = ['active', 'paused', 'idea', 'done'];

const grouped = statusOrder.reduce((acc, status) => {
  acc[status] = allPosts.filter(p => p.data.status === status);
  return acc;
}, {} as Record<string, typeof allPosts>);

const statusLabels: Record<string, string> = {
  active:  '🟢 Active',
  paused:  '⏸️  Paused',
  idea:    '💡 Ideas',
  done:    '✅ Done',
};

const featured = allPosts.find(p => p.data.featured);
---

<BaseLayout title="Projects">
  <!-- FEATURED: the one thing you're working on right now -->
  {featured && (
    <section style="margin-bottom: 2rem; padding: 1rem; border: 2px solid var(--color-accent);">
      <p style="margin:0 0 0.5rem; opacity:0.7; font-size:0.85rem;">NOW WORKING ON</p>
      <h2 style="margin:0 0 0.5rem;">
        <a href={`/posts/${featured.data.slug ?? featured.slug}`}>{featured.data.title}</a>
      </h2>
      {featured.data.next_step && (
        <p style="margin:0; font-size:0.9rem;">
          <strong>Next step:</strong> {featured.data.next_step}
        </p>
      )}
    </section>
  )}

  <!-- ALL PROJECTS grouped by status -->
  {statusOrder.map(status => grouped[status].length > 0 && (
    <section style="margin-bottom: 2rem;">
      <h3>{statusLabels[status]}</h3>
      <ul style="list-style:none; padding:0;">
        {grouped[status].map(post => (
          <li style="margin-bottom: 1rem; padding: 0.75rem; border: 1px solid var(--color-border);">
            <a href={`/posts/${post.data.slug ?? post.slug}`}>
              <strong>{post.data.title}</strong>
            </a>
            {post.data.last_updated && (
              <span style="margin-left:1rem; font-size:0.8rem; opacity:0.6;">
                last updated: {post.data.last_updated.toLocaleDateString()}
              </span>
            )}
            {post.data.next_step && (
              <div style="font-size:0.85rem; margin-top:0.25rem; opacity:0.8;">
                → {post.data.next_step}
              </div>
            )}
            {post.data.description && (
              <div style="font-size:0.85rem; margin-top:0.25rem;">{post.data.description}</div>
            )}
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>